# Copy this file to .env and fill in real secrets. NEVER commit .env to source control.

NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=airline_reservation
DB_USER=airline_app
DB_PASSWORD=change_me_dev_password
DB_SSL=false
DB_POOL_MAX=10

# --- Redis (sessions + seat-hold locks) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_dev_password
REDIS_TLS=false

# --- Sessions / Secrets ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_with_64_byte_random_hex
COOKIE_SECURE=false

# --- Security tuning ---
BCRYPT_COST=12
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
SEAT_HOLD_SECONDS=600

# --- Logging ---
LOG_LEVEL=info
